{
  "name": "htnq-trading-checklist",
  "version": "0.2.6",
  "description": "ICT + Quarterly Theory confluence and trade-logging tool",
  "main": "./out/main/index.js",
  "author": "HTNQ",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json --composite false",
    "dist": "electron-vite build && electron-builder",
    "dist:portable": "electron-vite build && electron-builder --win portable",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "release": "electron-vite build && electron-builder --publish always",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "build:web": "vite build --config vite.web.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.3.5",
    "autoprefixer": "^10.4.20",
    "dagre": "^0.8.5",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.3.3",
    "zustand": "^5.0.1"
  }
}
