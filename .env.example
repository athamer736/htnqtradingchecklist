# Supabase connection for cloud login + sync.
# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings -> API). Both values are safe to embed in the app; access
# is protected by Row-Level Security. Do NOT use the service_role key here.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Discord-gated login (Edge Function secrets) ----------------------------
# These are NOT used by the app build. They are set on Supabase for the
# verify-membership Edge Function only:
#   supabase secrets set DISCORD_BOT_TOKEN=... DISCORD_GUILD_ID=...
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are provided to functions
# automatically.) They are listed here purely as a reminder of what to
# configure - see supabase/README.md for the full walkthrough.
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_GUILD_ID=your-mentorship-server-id
